/********************************************************************************
* 
* McStas, neutron ray-tracing package
*         Copyright (C) 1997-2026, All rights reserved
*         Risoe National Laboratory, Roskilde, Denmark
*         Institut Laue Langevin, Grenoble, France
* 
* Instrument: Test_KDSource
* 
* %Identification
* Written by: Peter Willendrup
* Date: April 2026
* Origin: ESS
* %INSTRUMENT_SITE: Tests_MCPL_etc
* 
* Simple test instrument for KDSource
* 
* %Description
* Simple test instrument for KDSource, derived from the original KDS_resampled
* that was shipped / generated by Jupyter notebook Test_McStas_MPI.ipynb.
*
* Uses an KDSource XML description of bandwidths to apply when resampling the
* base MCPL input from samples.mcpl.gz
*
* %Example: nloop=1 Detector: PSDMon2_I=4056
* %Example: nloop=10 Detector: PSDMon2_I=4056
* %Example: nloop=100 Detector: PSDMon2_I=4056
* %Example: nloop=1000 Detector: PSDMon2_I=4056
*
* %Parameters
* nloop: [1] Number of reusages of KDSource input
*
* %Link
* 
* %End 
********************************************************************************/

DEFINE INSTRUMENT KDS_resampled (int nloop=1)

DECLARE 
%{
%}

INITIALIZE
%{
%}

TRACE 
COMPONENT Origin = Progress_bar()
AT (0, 0, 0) ABSOLUTE

COMPONENT Source = KDSource(
 filename = "source.xml",
 nloop=nloop)
AT (0, 0, 0) RELATIVE Origin

COMPONENT Norm = Monitor(
 xwidth = 0.4, yheight = 0.4)
AT (0, 0, 0.01) RELATIVE Origin

COMPONENT Slit1 = Slit(
 radius = 0.1)
AT (0, 0, 0.01) RELATIVE Origin

COMPONENT LMon1 = L_monitor(
 nL = 100, filename = "lmon1.dat",
 xwidth = 0.4, yheight = 0.4,
 Lmin = 0, Lmax = 5)
AT (0, 0, 0) RELATIVE Slit1

COMPONENT PSDMon1 = PSD_monitor(
 nx = 100, ny = 100,
 filename = "psdmon1.dat", xwidth = 0.4,
 yheight = 0.4)
AT (0, 0, 0) RELATIVE LMon1

COMPONENT Slit2 = Slit(
 radius = 0.1)
AT (0, 0, 0.223606797749979) RELATIVE Origin

COMPONENT LMon2 = L_monitor(
 nL = 100, filename = "lmon2.dat",
 xwidth = 0.4, yheight = 0.4,
 Lmin = 0, Lmax = 5)
AT (0, 0, 0) RELATIVE Slit2

COMPONENT PSDMon2 = PSD_monitor(
 nx = 100, ny = 100,
 filename = "psdmon2.dat", xwidth = 0.4,
 yheight = 0.4)
AT (0, 0, 0) RELATIVE LMon2

FINALLY 
%{
%}

END
