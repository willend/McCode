AT (0,0,1.9995+0.5*gGap) RELATIVE PREVIOUS

COMPONENT H151_8_Out = Al_window(thickness=5e-4)
AT (0,0,2.0) RELATIVE PREVIOUS

/* Gold foil activation is usually measured here */
COMPONENT h151cap = Monitor_nD(xwidth=0.04, yheight=0.03, bins=1, options="per cm2, capture")
AT (0,0,1e-3) RELATIVE PREVIOUS

/*** SAM instrument ***/

/*** Casemate ***/

/*** Velocity selector ***/

COMPONENT NVS_In = Al_window(thickness=5e-4)
AT (0,0,0.137) RELATIVE H151_8_Out

SPLIT COMPONENT NVS = Selector(
	xwidth=0.04, yheight=0.04, radius=0.115, alpha=35.04, 
	length=0.25, d=4e-4, nu=1540.2/lambdasel, nslit=96)
AT (0,0,0.03) RELATIVE PREVIOUS

COMPONENT NVS_Out = Al_window(thickness=5e-4)
AT (0,0,0.28) RELATIVE PREVIOUS

/*** Beam monitor ***/

COMPONENT Monitor_In = Al_window(thickness=1e-3)
AT (0,0,0.118) RELATIVE PREVIOUS

COMPONENT mon = Monitor_nD(xwidth=0.04, yheight=0.03, bins=1)
AT (0,0,0.0095) RELATIVE PREVIOUS

COMPONENT Monitor_Out = Al_window(thickness=1e-3)
AT (0,0,0.0095) RELATIVE PREVIOUS

/*** Polarizer/guide changer ***/

COMPONENT Vacuum_Window_In = Al_window(thickness=5e-4)
AT (0,0,gGap) RELATIVE PREVIOUS

COMPONENT CasemateGuide = Guide_gravity(w1=0.03, h1=0.03, l=1.37, m=1, alpha=gAlpha, wavy=gWavy)
AT (0,0,0.042) RELATIVE Vacuum_Window_In 

/*** RF flipper ***/

COMPONENT RFflipper_In = Arm()
AT (0,0,1.37) RELATIVE Vacuum_Window_In

COMPONENT RFflipperGuide = Guide_gravity(w1=0.03, h1=0.03, l=0.91, m=1, alpha=gAlpha, wavy=gWavy)
AT (0,0,0.013) RELATIVE RFflipper_In 

/*** Collimator ***/

COMPONENT Collimator_In = Arm()
AT (0,0,0.91) RELATIVE RFflipper_In

COMPONENT Dia1 = Slit(xwidth=s1w, yheight=s1h) 
AT (0,0,0.05) RELATIVE Collimator_In

COMPONENT CollimatorGuide1 = Guide_gravity(w1=0.03, h1=0.03, l=1.969, m=1, alpha=gAlpha, wavy=gWavy) 
WHEN (guide1 == 1)
AT (0,0,0.097) RELATIVE Collimator_In 

COMPONENT CollimatorGuide2 = Guide_gravity(w1=0.03, h1=0.03, l=1.969, m=1, alpha=gAlpha, wavy=gWavy) 
WHEN (guide2 == 1)
AT (0,0,2.072) RELATIVE Collimator_In 

COMPONENT Dia2 = Slit(xwidth=s2w, yheight=s2h) 
AT (0,0,4.065) RELATIVE Collimator_In

COMPONENT CollimatorGuide3 = Guide_gravity(w1=0.03, h1=0.03, l=2.441, m=1, alpha=gAlpha, wavy=gWavy) 
WHEN (guide3 == 1)	
AT (0,0,4.089) RELATIVE Collimator_In 

COMPONENT Dia3 = Slit(xwidth=s3w, yheight=s3h) 
AT (0,0,6.554) RELATIVE Collimator_In

COMPONENT SampleSlitPos = Arm()
AT (0,0,2.45) RELATIVE Dia3

COMPONENT SampleSlit_Rect = Slit(xwidth=ssw, yheight=ssh)
WHEN(ssshape==1) AT (0,0,0) RELATIVE SampleSlitPos

COMPONENT SampleSlit_Circ = Slit(radius=0.5*ssw)
WHEN(ssshape==2) AT (0,0,0) RELATIVE SampleSlitPos

/*** Sample position ***/

COMPONENT sample = Monitor_nD(xwidth=ssw, yheight=ssh, bins=1)
AT (0,0,0.045) RELATIVE SampleSlitPos

COMPONENT SamplePos = Arm()
AT (0,0,0.05) RELATIVE SampleSlitPos

SPLIT COMPONENT H2O = Incoherent(
	sigma_abs=0.665, sigma_inc=160.521, Vc=29.969,
	xwidth=1e-2, yheight=4e-2, zdepth=1e-3, 
	p_interact=1, focus_xw=0.64, focus_yh=0.64, target_z=lsd)
WHEN(sampleno==1) AT (0,0,0) RELATIVE SamplePos

SPLIT COMPONENT AgBeh = Powder1(d=58.4, d_phi=tthmax*RAD2DEG, xwidth=1e-2, yheight=4e-2, zdepth=1e-3)
WHEN(sampleno==2) AT (0,0,0) RELATIVE SamplePos

SPLIT COMPONENT Spheres = Sans_spheres(
	R=100, Phi=1e-3, Delta_rho=1.0, 
	xwidth=1e-2, yheight=4e-2, zdepth=1e-3,
	focus_xw=0.64, focus_yh=0.64, target_z=lsd)
WHEN(sampleno==3) AT (0,0,0) RELATIVE SamplePos

/*** 3He monoblock PSD ***/

COMPONENT BS = Beamstop(radius=rbs)
AT (0,0,lsd-0.11) RELATIVE SamplePos

COMPONENT psd = PSD_monitor(xwidth=0.64, yheight=0.64, nx=256, ny=128, filename="psd.dat")
AT (0,0,lsd) RELATIVE SamplePos

END
