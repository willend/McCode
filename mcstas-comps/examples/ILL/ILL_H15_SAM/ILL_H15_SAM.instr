/* 
* WP1.13/SAM GUIDE (H151): 
* L = 12 m, W = 40 mm, H = 30 mm, R = -1500 m, m = [1,1,1.6,1] [T,B,L,R]
* L = 4 m, W = 40 mm, H = 30 mm, straight, m = [1,1,1,1] [T,B,L,R]
*/

/* End of secondary shutter gap */
COMPONENT H151_1_In = Al_window(thickness=5e-4)
AT (0,0,0.12) RELATIVE H15_C11_7_Out
ROTATED (0,-1.9995/1.5e3*RAD2DEG,0) RELATIVE H15_C11_7_Out

COMPONENT H151_1 = Guide_gravity(
