COMPONENT fo_chopper_1a = DiskChopper(
    theta_0 = theta_fo_1a_cut*RAD2DEG, radius = radius_foc1, yheight = window_height_foc1, nu = actual_fo_1, nslit = 1,
    phase = phi_fo_1a*RAD2DEG, jitter=jit_FOC1_sec)
